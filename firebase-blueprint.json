{
  "entities": {
    "Frame": {
      "title": "Frame",
      "description": "A single frame of the scroll animation",
      "type": "object",
      "properties": {
        "index": {
          "type": "integer",
          "description": "The index of the frame for sorting"
        },
        "frameNum": {
          "type": "string",
          "description": "The frame number (e.g., '0.1')"
        },
        "data": {
          "type": "string",
          "description": "Base64 encoded image data"
        },
        "mimeType": {
          "type": "string",
          "description": "The MIME type of the image"
        }
      },
      "required": ["index", "frameNum", "data", "mimeType"]
    }
  },
  "firestore": {
    "/frames/{frameId}": {
      "schema": "Frame",
      "description": "Collection of animation frames"
    }
  }
}
